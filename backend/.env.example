# Application
APP_NAME=AI Tax Engine
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_tax

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-in-production-with-secure-key

# AI Provider
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EXTRACTION_MODEL=gpt-4o

# Anthropic (alternative)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-haiku-20240307
ANTHROPIC_EXTRACTION_MODEL=claude-3-sonnet-20240229

# Plaid (optional)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# QuickBooks (optional)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:8000/api/v1/quickbooks/callback

# Xero (optional)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:8000/api/v1/xero/callback

# Classification
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.70
AUTO_CLASSIFY_ON_IMPORT=true

# Tax
DEFAULT_TAX_YEAR=2024
